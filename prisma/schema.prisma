generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
}

model Employee {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  username  String   @unique
  email     String?
  phone     String?
  gender    String?
  status    String   @default("Aktif")
  password  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      String?
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  stock     Int
  createdAt DateTime @default(now())
}

model Order {
  id         Int      @id @default(autoincrement())
  totalPrice Float
  createdAt  DateTime @default(now())
}

model Customer {
  id        Int        @id @default(autoincrement())
  firstName String
  lastName  String
  barcode   String     @unique
  bonus     Float      @default(0)
  gender    String?
  email     String?
  phone     String?
  address   String?
  city      String?    @default("Bakı")
  country   String?    @default("Azərbaycan")
  notes     String?
  createdBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  giftCards GiftCard[]
}

model GiftCard {
  id         Int       @id @default(autoincrement())
  barcode    String    @unique
  value      Float     @default(0)
  customerId Int?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer? @relation(fields: [customerId], references: [id])
}
