generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
}

model Employee {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  username  String   @unique
  email     String?
  phone     String?
  gender    String?
  status    String   @default("Aktif")
  password  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      String?
}

model Product {
  id                Int       @id @default(autoincrement())
  productName       String
  brandName         String?   // Store array as JSON
  category          String?   // Store array as JSON
  barcode           String?   @unique
  description       String?
  images            String?   // Store array/JSON URLs
  wholesalePrice    Float?    @default(0)
  retailPrice       Float?    @default(0)
  stock             Int?      @default(0)
  reorderLevel      Int?      @default(0)
  attribute         String?   // Store as JSON for variants (e.g. ["Size: M"])
  
  parentProductId   Int?
  parentProduct     Product?  @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: Cascade)
  variants          Product[] @relation("ProductVariants")
  
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Order {
  id         Int      @id @default(autoincrement())
  totalPrice Float
  createdAt  DateTime @default(now())
}

model Customer {
  id        Int        @id @default(autoincrement())
  firstName String
  lastName  String
  barcode   String     @unique
  bonus     Float      @default(0)
  gender    String?
  email     String?
  phone     String?
  address   String?
  city      String?    @default("Bakı")
  country   String?    @default("Azərbaycan")
  notes     String?
  createdBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  giftCards GiftCard[]
}

model GiftCard {
  id         Int       @id @default(autoincrement())
  barcode    String    @unique
  value      Float     @default(0)
  customerId Int?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer? @relation(fields: [customerId], references: [id])
}
model Attribute {
  id        Int      @id @default(autoincrement())
  name      String
  values    String   // Store as JSON string or comma-separated
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  employeeName  String?  // Who made the expense
  amount        Float    @default(0)
  category      String?
  paymentMethod String?
  notes         String?
  createdBy     String?  // Who recorded the expense
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Supplier {
  id          Int      @id @default(autoincrement())
  brandName   String
  companyName String?  // Store as JSON array
  firstName   String?
  lastName    String?
  email       String?
  phone       String?
  voen        String?  // Store as JSON array
  address     String?
  city        String?  // Store as JSON array
  country     String?  @default("AZ")
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String?  @default("lucide:credit-card")
  color     String?  @default("blue")
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
