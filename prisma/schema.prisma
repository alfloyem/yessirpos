generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id         Int      @id @default(autoincrement())
  firstName  String
  lastName   String
  username   String   @unique
  email      String?
  phone      String?
  gender     String?
  status     String   @default("Aktif")
  password   String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  role       String?
  notAllowed String?  // Store as JSON array of restricted paths
  fcmTokens  String?  // Store as JSON array of tokens
}

model Product {
  id              Int       @id @default(autoincrement())
  productName     String
  brandName       String?   // Store array as JSON
  category        String?   // Store array as JSON
  barcode         String?   @unique
  description     String?
  images          String?   // Store array/JSON URLs
  wholesalePrice  Float?    @default(0)
  retailPrice     Float?    @default(0)
  stock           Int?      @default(0)
  reorderLevel    Int?      @default(0)
  attribute       String?   // Store as JSON for variants (e.g. ["Size: M"])
  
  discountValue   Float?    @default(0)
  discountType    String?   @default("percent") // "percent" or "amount"
  isSaleActive    Boolean?  @default(false)
  
  parentProductId Int?
  parentProduct   Product?  @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: Cascade)
  variants        Product[] @relation("ProductVariants")
  
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNo       String      @unique
  customerId    Int?
  customerName  String?
  customerEmail String?
  customerPhone String?
  address       String?
  city          String?
  country       String?     @default("Azərbaycan")
  notes         String?
  subtotal      Float       @default(0)
  deliveryFee   Float       @default(0)
  totalPrice    Float
  paymentMethod String?     @default("cash")
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int
  productId   Int?
  productName String
  image       String?
  price       Float  @default(0)
  qty         Int    @default(1)
  total       Float  @default(0)
  attributes  String?
  Order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Customer {
  id                  Int                   @id @default(autoincrement())
  firstName           String?
  lastName            String?
  barcode             String                @unique
  bonus               Float                 @default(0)
  gender              String?
  email               String?               @unique
  phone               String?
  address             String?
  city                String?               @default("Bakı")
  country             String?               @default("Azərbaycan")
  notes               String?
  createdBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  password            String?
  isVerified          Boolean               @default(false)
  verificationToken   String?
  resetToken          String?
  debt                Float                 @default(0)
  CustomerDebtPayment CustomerDebtPayment[]
  giftCards           GiftCard[]
  googleId            String?               @unique
  reviews             Review[]
}

model Review {
  id         Int      @id @default(autoincrement())
  productId  Int
  customerId Int
  rating     Float    // 0.5 - 5.0 in 0.5 steps
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model GiftCard {
  id         Int       @id @default(autoincrement())
  barcode    String    @unique
  value      Float     @default(0)
  customerId Int?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer? @relation(fields: [customerId], references: [id])
}

model Attribute {
  id        Int      @id @default(autoincrement())
  name      String
  values    String   // Store as JSON string or comma-separated
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  employeeName  String?  // Who made the expense
  amount        Float    @default(0)
  category      String?
  paymentMethod String?
  notes         String?
  createdBy     String?  // Who recorded the expense
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Supplier {
  id          Int      @id @default(autoincrement())
  brandName   String
  companyName String?  // Store as JSON array
  firstName   String?
  lastName    String?
  email       String?
  phone       String?
  voen        String?  // Store as JSON array
  address     String?
  city        String?  // Store as JSON array
  country     String?  @default("AZ")
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String?  @default("lucide:credit-card")
  color     String?  @default("blue")
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id              Int        @id @default(autoincrement())
  receiptNo       String     @unique // 13 digits padded
  subtotal        Float      @default(0)
  discountTotal   Float      @default(0)
  finalTotal      Float      @default(0)
  cashbackEarned  Float      @default(0)
  
  // Payment methods and other details as JSON string
  paymentDetails  String?    
  
  cashierId       Int?
  cashierName     String?
  
  customerId      Int?
  customerName    String?
  customerBarcode String?

  items           SaleItem[]
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model SaleItem {
  id              Int      @id @default(autoincrement())
  saleId          Int
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId       Int?
  productName     String
  barcode         String?
  qty             Float    @default(1)
  price           Float    @default(0)
  wholesalePrice  Float?   @default(0)
  discount        Float    @default(0)
  total           Float    @default(0)
  
  attribute       String?  // JSON string
}

model Intake {
  id              Int             @id @default(autoincrement())
  receiptNo       String          @unique // RXXXXXXX format
  supplierId      Int?
  supplierName    String?
  totalAmount     Float           @default(0)
  paidAmount      Float           @default(0)
  balanceDue      Float           @default(0)
  paymentMethod   String?
  notes           String?
  items           IntakeItem[]
  payments        IntakePayment[]
  createdBy       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model IntakeItem {
  id              Int      @id @default(autoincrement())
  intakeId        Int
  intake          Intake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  productId       Int
  productName     String
  barcode         String?
  qty             Float    @default(0)
  costPrice       Float    @default(0) // Price per item
  discount        Float    @default(0) // Discount per item
  discountType    String   @default("amount") // "amount" or "percent"
  total           Float    @default(0)
  attribute       String?  // JSON string
}

model IntakePayment {
  id            Int      @id @default(autoincrement())
  receiptNo       String   @unique // DP0000001 format
  intakeId      Int
  intake        Intake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  amount        Float    @default(0)
  paymentMethod String?
  paidBy        String?
  notes         String?
  createdAt     DateTime @default(now())
}

model CustomerDebtPayment {
  id              Int      @id @default(autoincrement())
  receiptNo       String   @unique // DXXXXXXX format
  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id])
  customerName    String?
  customerBarcode String?
  amount          Float    @default(0)
  remainingDebt   Float    @default(0)
  paymentMethod   String?
  notes           String?
  cashierId       Int?
  cashierName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // SALE, CUSTOMER_ADDED, PRODUCT_ADDED, LOW_STOCK, REFUND, INTAKE, DEBT_PAYMENT
  title     String
  message   String?
  data      String?  // JSON string for additional metadata
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
