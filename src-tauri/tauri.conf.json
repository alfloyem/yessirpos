{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yessirpos",
  "version": "0.1.911",
  "identifier": "com.yessir.pos",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm generate"
  },
  "app": {
    "windows": [
      {
        "title": "YesSir POS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxRDYzQUEzREQ4ODgwOTAKUldTUWdJamRvenJXa2RzMHoyS1J1ZEhHUFNrKzIzOFVRVjZORHYvTll2ZzF4VnV5SU5BRk9qWUYK",
      "endpoints": [
        "https://raw.githubusercontent.com/alfloyem/yessirpos-vue/master/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
