{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yessirpos",
  "version": "0.1.4",
  "identifier": "com.yessir.pos",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm generate"
  },
  "app": {
    "windows": [
      {
        "title": "YesSir POS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFODY5QUIyQTkxMkE0NjkKUldScHBCS3BzcHFHTHV2dEdJZ2ZUZDFyZkJqcmtyUXk2THF6NHJlekdKS3ZrYXBDTnZZS1QyY1MK",
      "endpoints": [
        "https://raw.githubusercontent.com/alfloyem/yessirpos-vue/main/update.json"
      ]
    }
  }
}
