# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=""

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=""

# ─── Prisma ───────────────────────────────────────────────────────────────────
PRISMA_CLIENT_ENGINE_TYPE="library"

# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of this POS app (used for API calls from client)
NUXT_PUBLIC_API_URL="https://pos.bakustreet.az"
# Client identifier used for multi-tenant branding (default: bakustreet)
CLIENT_ID="bakustreet"

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
# Client config is hardcoded in nuxt.config.ts (public, safe to expose)
# Only these two are secret / environment-specific:
FIREBASE_VAPID_KEY=""
# Path to service account JSON (relative to project root, never commit the file)
FIREBASE_SERVICE_ACCOUNT_PATH="firebase/yessirpos-firebase-adminsdk-fbsvc-345b44c4a5.json"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Absolute path to shared image directory (symlinked from bsweb & bspos public/)
# Example: /root/BakuStreet/img/product-images
IMG_DIR=""
